### 26.pod ###
[Pod]
PodName=26
PublishPort=8080:80
PublishPort=4443:443

### caddy.container ###
[Container]
Image=caddy:2-alpine
Pod=26.pod
Volume=./Caddyfile:/etc/caddy/Caddyfile:ro
Volume=caddy_data:/data
Volume=caddy_config:/config

[Service]
Restart=always

### webapp.container ###
[Container]
Image=nginx:alpine
Pod=26.pod
Volume=./html:/usr/share/nginx/html:ro

[Service]
Restart=always
