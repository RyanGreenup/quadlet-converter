# Maintainer: quadlet-serde contributors
pkgname=quadlet-serde
pkgver=VERSION
pkgrel=1
pkgdesc="CLI tool for converting between Docker Compose and Podman Quadlet formats"
arch=('x86_64')
url="https://github.com/quadlet-serde/quadlet-serde"
license=('MIT')
depends=()
source=("$pkgname-$pkgver::https://github.com/quadlet-serde/quadlet-serde/releases/download/v$pkgver/quadlet-serde-linux-x64")
sha256sums=('SKIP')

package() {
    install -Dm755 "$srcdir/$pkgname-$pkgver" "$pkgdir/usr/bin/$pkgname"
}
